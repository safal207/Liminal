{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/safal207/Liminal/blob/main/schemas/codex-operational-checkpoint-v0.1.schema.json",
  "title": "Codex Operational Checkpoint v0.1",
  "description": "A bounded checkpoint for preserving operational continuity across Codex compaction and thread handoff without carrying tool authorization forward.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_version",
    "checkpoint_id",
    "session_id",
    "created_at",
    "trigger",
    "workspace",
    "task",
    "operational_tail",
    "next_action",
    "authority"
  ],
  "properties": {
    "profile_version": {
      "type": "string",
      "const": "0.1"
    },
    "checkpoint_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "trajectory_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256,
      "default": null
    },
    "parent_checkpoint_id": {
      "type": ["string", "null"],
      "minLength": 1,
      "maxLength": 256,
      "default": null
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trigger": {
      "type": "string",
      "enum": ["auto_compact", "manual_compact", "handoff", "provider_limit", "session_end"]
    },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd", "repository_id", "git_head"],
      "properties": {
        "cwd": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2048
        },
        "repository_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "git_head": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,64}$"
        },
        "dirty_state_digest": {
          "type": ["string", "null"],
          "pattern": "^sha256:[a-f0-9]{64}$",
          "default": null
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "current_phase"],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        },
        "current_phase": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    },
    "operational_tail": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step_id", "step_type", "content_ref", "content_digest"],
        "properties": {
          "step_id": {
            "type": "string",
            "minLength": 1,
            "maxLength": 256
          },
          "step_type": {
            "type": "string",
            "enum": [
              "user_instruction",
              "assistant_intent",
              "tool_call",
              "tool_result",
              "decision",
              "verification"
            ]
          },
          "content_ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          },
          "content_digest": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "summary": {
            "type": ["string", "null"],
            "maxLength": 2000,
            "default": null
          }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "must": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        },
        "must_not": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        },
        "rejected_approaches": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approach", "reason"],
            "properties": {
              "approach": {
                "type": "string",
                "maxLength": 1000
              },
              "reason": {
                "type": "string",
                "maxLength": 2000
              }
            }
          },
          "maxItems": 32,
          "default": []
        }
      },
      "default": {}
    },
    "touched_resources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["resource", "status"],
        "properties": {
          "resource": {
            "type": "string",
            "maxLength": 2048
          },
          "status": {
            "type": "string",
            "enum": ["read", "modified", "created", "deleted", "verified"]
          },
          "digest": {
            "type": ["string", "null"],
            "pattern": "^sha256:[a-f0-9]{64}$",
            "default": null
          }
        }
      },
      "maxItems": 256,
      "default": []
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        },
        "completed": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        },
        "pending": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        }
      },
      "default": {}
    },
    "next_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "target_ref": {
          "type": ["string", "null"],
          "maxLength": 2048,
          "default": null
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 1000
          },
          "maxItems": 32,
          "default": []
        }
      }
    },
    "authority": {
      "type": "string",
      "const": "context_only",
      "description": "The checkpoint preserves context and continuity evidence only; it does not authorize tool execution."
    }
  }
}
